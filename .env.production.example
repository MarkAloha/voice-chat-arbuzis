# Скопируйте на сервер: cp .env.production.example .env

# Общий пароль для входа на сайт
SITE_PASSWORD=change-me-to-strong-password

# Домены через запятую — SSR и Caddy (все, что в Caddyfile)
SITE_HOST=voice-chat-arbuzis.duckdns.org,arbuzis.ru,www.arbuzis.ru,arbuzis.online,www.arbuzis.online

# LiveKit — сгенерируйте свой секрет (минимум 32 символа)
LIVEKIT_API_KEY=lk_arbuzis
LIVEKIT_API_SECRET=replace-with-long-random-secret-min-32-chars

# Публичный IP VPS (для WebRTC)
LIVEKIT_NODE_IP=YOUR_VPS_IP

# Fallback WebSocket LiveKit; в /api/join клиент получает wss://<текущий-домен>/livekit
LIVEKIT_URL=wss://arbuzis.online/livekit
# Внутренний URL LiveKit API для app-контейнера (счётчик участников)
LIVEKIT_API_URL=http://livekit:7880

ROOM_NAME=main
ROOM_MAX_PARTICIPANTS=5
