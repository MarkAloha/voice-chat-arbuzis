{
  "name": "voice-chat-arbuzis",
  "version": "1.5.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "api": "tsx dev-api.ts",
    "dev": "concurrently -n api,web -c blue,green \"npm run api\" \"npm run start\"",
    "livekit": "docker compose up",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:voice-chat-arbuzis": "node dist/voice-chat-arbuzis/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.17",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "livekit-client": "^2.20.0",
    "livekit-server-sdk": "^2.15.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.17",
    "@angular/compiler-cli": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "concurrently": "^10.0.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
